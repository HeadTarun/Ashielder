# Google ADK / Gemini
# Use the model name your ADK install supports. Keep this low-latency for hackathon demos.
GEMINI_MODEL=gemini-flash-latest

# Groq fallback through LiteLLM. Requires a valid key if you use fallback_agent.
GROQ_MODEL=groq/llama-3.1-70b-versatile
GROQ_API_KEY=

# Optional Google credentials / API key, depending on how you run ADK.
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Local ONNX model directories. Defaults already point to these relative folders.
DISTILBERT_MODEL_PATH=distilbert_m2
LIGHTURLNET_MODEL_PATH=lighturlnet
EMBEDDING_MODEL_PATH=embed

# Routing labels. Tune these after you know what each classifier label means.
DISTILBERT_URL_LABELS=LABEL_0
DISTILBERT_ANALYSIS_LABELS=LABEL_1
DISTILBERT_MIN_CONFIDENCE=0.5

# URL threat-intelligence enrichment. Safe Browsing is optional; if unset, the
# decision tool reports it as an unknown instead of inventing a clean result.
SAFE_BROWSING_API_KEY=AIzabBcccccccccccccccccccccccccccccc
RDAP_TIMEOUT_SECONDS=5
INTEL_CORPUS_PATH=knowledge/intel_corpus.json

# Gmail read-only OAuth for mailbox security diagnosis. Configure these from a
# Google OAuth web client and keep the token encryption key secret.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8001/oauth2callback
GMAIL_TOKEN_DB_PATH=data/gmail_tokens.db
GMAIL_TOKEN_ENCRYPTION_KEY=
GMAIL_FETCH_LIMIT=10
